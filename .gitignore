# OCAX .gitignore

# ===========================================
# Environment & Secrets
# ===========================================
.env
.env.local
.env.*
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
credentials.json
secrets.json
token.json
*.secret

# ===========================================
# Python
# ===========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
ENV/
env/
.conda/

# ===========================================
# Node.js
# ===========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json

# ===========================================
# IDEs & Editors
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
.project
.settings/
.classpath
*.sublime-*

# ===========================================
# Logs & Temp Files
# ===========================================
*.log
*.tmp
*.temp
*.bak
*.backup
*.cache
*.swp
*.swo
*~
logs/
tmp/
temp/

# ===========================================
# OpenClaw Specific
# ===========================================
.clawhub/
.openclaw/
.openclaw.local/
*.state.json
workspace-state.json

# ===========================================
# OCAX Specific
# ===========================================
release/
output/
results/
*.xlsx.bak

# ===========================================
# OS Files
# ===========================================
Thumbs.db
.DS_Store
desktop.ini
$RECYCLE.BIN/

# ===========================================
# Build Outputs
# ===========================================
dist/
build/
out/
*.exe
*.dll
*.so
*.dylib

# ===========================================
# Keep These (Do NOT Ignore)
# ===========================================
# !README.md
# !docs/
# !scripts/
# !skills/
